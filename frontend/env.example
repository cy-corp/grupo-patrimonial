# -----------------------------------------------------------------------------
# Supabase
# Encontre em: supabase.com → seu projeto → Settings → API
# -----------------------------------------------------------------------------

# URL do projeto (seguro expor no frontend)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Publishable key — usada no cliente (seguro expor no frontend, desde que RLS esteja ativo)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# Vercel Blob
# Gerado automaticamente ao conectar um Blob Store no dashboard da Vercel:
# vercel.com → seu projeto → Storage → Connect Store → Blob
# -----------------------------------------------------------------------------

# Token de leitura e escrita — usar APENAS no servidor
# NUNCA prefixe com NEXT_PUBLIC_
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx...
